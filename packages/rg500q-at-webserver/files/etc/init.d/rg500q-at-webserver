#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/rg500q-at-webserver

start_service() {
	local enabled

	config_load rg500q-at-webserver
	config_get_bool enabled config enabled 1

	[ "$enabled" = "1" ] || {
		logger -t rg500q-at-webserver "service disabled"
		return 0
	}

	[ -x "$PROG" ] || {
		logger -t rg500q-at-webserver "missing executable: $PROG"
		return 1
	}

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "rg500q-at-webserver"
}

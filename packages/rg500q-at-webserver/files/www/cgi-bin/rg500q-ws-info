#!/bin/sh

echo "Content-Type: application/json"
echo "Access-Control-Allow-Origin: *"
echo ""

WS_PORT="$(uci -q get rg500q-at-webserver.config.websocket_port)"
AUTH_KEY="$(uci -q get rg500q-at-webserver.config.auth_key)"
[ -n "$WS_PORT" ] || WS_PORT=8765

if [ -n "$AUTH_KEY" ]; then
	REQUIRE_AUTH=true
else
	REQUIRE_AUTH=false
fi

if [ -n "$HTTP_HOST" ]; then
	case "$HTTP_HOST" in
		\[*\]:*) WS_HOST="${HTTP_HOST#\[}"; WS_HOST="${WS_HOST%%\]:*}" ;;
		\[*\]) WS_HOST="${HTTP_HOST#\[}"; WS_HOST="${WS_HOST%\]}" ;;
		*:*:*) WS_HOST="$HTTP_HOST" ;;
		*:*) WS_HOST="${HTTP_HOST%%:*}" ;;
		*) WS_HOST="$HTTP_HOST" ;;
	esac
fi

if [ -z "$WS_HOST" ]; then
	WS_HOST="$(uci -q get network.lan.ipaddr)"
	[ -n "$WS_HOST" ] || WS_HOST="192.168.123.1"
fi

case "$WS_HOST" in
	*:*:*) WS_URL="ws://[${WS_HOST}]:${WS_PORT}" ;;
	*) WS_URL="ws://${WS_HOST}:${WS_PORT}" ;;
esac

cat <<EOF
{
  "success": true,
  "data": {
    "host": "${WS_HOST}",
    "port": ${WS_PORT},
    "require_auth": ${REQUIRE_AUTH},
    "ws_url": "${WS_URL}",
    "timestamp": $(date +%s)
  }
}
EOF

#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

start_service() {
    local enabled
    config_load ledstatus
    config_get enabled settings enabled '1'

    if [ -d /sys/class/leds/green:power ]; then
        echo none > /sys/class/leds/green:power/trigger
        echo 1 > /sys/class/leds/green:power/brightness
    fi

    /usr/bin/aw1000-phone-led-sync.sh

    [ "$enabled" = "0" ] && return 0

    # If night mode is currently active, don't start the LED daemon yet —
    # the cron job for night_end will call 'led-night-mode.sh off' which
    # will restart this service once the window ends.
    [ -f /tmp/led-night-active ] && return 0

    procd_open_instance
    procd_set_param command /usr/bin/led-status-check-daemon.sh
    procd_set_param respawn
    procd_close_instance

    logger -t ledstatus "LED status service started"
}

stop_service() {
    :
}

reload_service() {
    /usr/bin/aw1000-phone-led-sync.sh
    restart
}

service_triggers() {
    procd_add_reload_trigger "ledstatus"
}
